# Copy this file to .env on the Raspberry Pi and change every secret before production use.

MOSQUITTO_IMAGE=eclipse-mosquitto:2.0
INFLUXDB_IMAGE=influxdb:2.7
TELEGRAF_IMAGE=telegraf:1.28
GRAFANA_IMAGE=grafana/grafana:13.0.1
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.3.0

INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change-me-influx-password
INFLUXDB_ORG=weatherstation
INFLUXDB_BUCKET=sensors
INFLUXDB_ADMIN_TOKEN=change-me-influx-token

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_DOMAIN=localhost
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ANONYMOUS_ORG_ROLE=Viewer
GRAFANA_ALLOW_EMBEDDING=true

# Optional. Start with: docker compose --profile tunnel up -d
CLOUDFLARE_TUNNEL_TOKEN=
